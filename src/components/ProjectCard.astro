---
const { p } = Astro.props;
const tags = [p.platform, p.category];
const desc = `${p.platform} build — ${p.category.toLowerCase()} project, delivered production-ready.`;
---
<article class="proj reveal" data-cat={p.category}>
  <div class="proj-shot">
    <span class="proj-cat">{p.category}</span>
    <img src={p.img} alt={`${p.title} — screenshot`} loading="lazy" decoding="async" />
  </div>
  <div class="proj-body">
    <h3>{p.title}</h3>
    <div class="loc">{p.platform}</div>
    <div class="tags">{tags.map((t) => <b>{t}</b>)}</div>
    <div class="proj-actions">
      {p.live
        ? <a class="live" href={p.live} target="_blank" rel="noopener">Live demo ↗</a>
        : <span class="case">Case study</span>}
    </div>
  </div>
</article>
