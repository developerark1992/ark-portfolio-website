---
import Base from '../layouts/Base.astro';
import projectsRaw from '../data/projects.json';

// newest first — new MEGA syncs (real timestamps) float above the seeded set
const projects = [...projectsRaw].sort((a, b) => new Date(b.added || 0) - new Date(a.added || 0));

const counts = {};
projects.forEach((p) => { counts[p.category] = (counts[p.category] || 0) + 1; });
const cats = [['all', 'All', projects.length]].concat(
  Object.keys(counts).sort().map((c) => [c, c, counts[c]])
);
---
<Base active="projects" title="Projects — Abdul Rehman Khan" description="90+ web, e-commerce and app builds by Abdul Rehman Khan across WordPress, Shopify, Webflow, Wix, Squarespace, Framer and custom stacks.">
  <section style="padding-bottom:0;">
    <div class="wrap">
      <p class="eyebrow reveal">Portfolio</p>
      <h1 class="reveal" style="font-size:clamp(32px,5.4vw,58px);margin-bottom:16px;">All projects.</h1>
      <p class="sec-lead reveal" style="margin-bottom:32px;">{projects.length} production builds across healthcare, real estate, e-commerce, finance, agencies and more — Pakistan, the UAE, Canada and beyond. Search by name or platform, or filter by category.</p>

      <div class="proj-search reveal">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.8"/><path d="m20 20-3.2-3.2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/></svg>
        <input id="projSearch" type="search" placeholder="Search projects — try “Shopify”, “dental”, “Prescott”…" autocomplete="off" aria-label="Search projects" />
        <button id="projSearchClear" type="button" aria-label="Clear search" hidden>×</button>
      </div>

      <div class="filters reveal" id="projFilters">
        {cats.map(([key, label, n], i) => (
          <button class={`filt ${i === 0 ? 'active' : ''}`} data-filter={key}>{label}<span class="count">{n}</span></button>
        ))}
      </div>
    </div>
  </section>

  <section style="padding-top:28px;">
    <div class="wrap">
      <div class="proj-grid" id="allProjects"></div>
      <p class="proj-empty" id="projEmpty" hidden>No projects match — try a different search.</p>
      <div class="proj-sentinel" id="projSentinel" aria-hidden="true"></div>
      <p class="proj-count mono" id="projShowing"></p>
    </div>
  </section>

  <!-- lightbox -->
  <div class="lb" id="lb" hidden aria-hidden="true" role="dialog" aria-modal="true" aria-label="Project preview">
    <button class="lb-x" id="lbClose" aria-label="Close preview">×</button>
    <div class="lb-inner" id="lbInner">
      <div class="lb-shot"><img id="lbImg" src="" alt="" /></div>
      <aside class="lb-side">
        <span class="lb-cat" id="lbCat"></span>
        <h3 id="lbTitle"></h3>
        <div class="lb-tags" id="lbTags"></div>
        <div class="lb-actions" id="lbActions"></div>
        <p class="lb-note mono">Full-page screenshot — scroll the preview to see the whole design.</p>
      </aside>
    </div>
  </div>

  <script is:inline define:vars={{ PROJECTS: projects }}>
    document.addEventListener('astro:page-load', function () {
      var grid = document.getElementById('allProjects');
      if (!grid) return; // not the projects page

      var BATCH = 6;
      var state = { q: '', cat: 'all', shown: 0, list: [] };
      var search = document.getElementById('projSearch');
      var clearBtn = document.getElementById('projSearchClear');
      var filters = document.getElementById('projFilters');
      var sentinel = document.getElementById('projSentinel');
      var empty = document.getElementById('projEmpty');
      var showing = document.getElementById('projShowing');

      function esc(s){return String(s==null?'':s).replace(/[&<>"]/g,function(c){return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[c];});}

      function filtered() {
        var q = state.q.trim().toLowerCase();
        return PROJECTS.filter(function (p) {
          if (state.cat !== 'all' && p.category !== state.cat) return false;
          if (!q) return true;
          return ((p.title||'') + ' ' + (p.platform||'') + ' ' + (p.category||'')).toLowerCase().indexOf(q) !== -1;
        });
      }

      function cardHTML(p, i) {
        var live = p.live
          ? '<a class="live" href="' + esc(p.live) + '" target="_blank" rel="noopener" data-live>Live demo ↗</a>'
          : '<span class="case">Case study</span>';
        return '<article class="proj proj-appear" data-idx="' + i + '" tabindex="0" role="button" aria-label="Preview ' + esc(p.title) + '" style="animation-delay:' + ((i % BATCH) * 0.05) + 's">' +
          '<div class="proj-shot"><span class="proj-cat">' + esc(p.category) + '</span>' +
          '<img src="' + esc(p.img) + '" alt="' + esc(p.title) + ' — screenshot" loading="lazy" decoding="async" />' +
          '<span class="proj-view">View ↗</span></div>' +
          '<div class="proj-body"><h3>' + esc(p.title) + '</h3>' +
          '<div class="loc">' + esc(p.platform) + '</div>' +
          '<div class="tags"><b>' + esc(p.platform) + '</b><b>' + esc(p.category) + '</b></div>' +
          '<div class="proj-actions">' + live + '</div></div></article>';
      }

      function renderNext() {
        var next = state.list.slice(state.shown, state.shown + BATCH);
        if (!next.length) return;
        var html = '';
        for (var k = 0; k < next.length; k++) html += cardHTML(next[k], state.shown + k);
        grid.insertAdjacentHTML('beforeend', html);
        state.shown += next.length;
        updateCount();
      }

      function updateCount() {
        showing.textContent = state.list.length
          ? 'Showing ' + Math.min(state.shown, state.list.length) + ' of ' + state.list.length + (state.cat === 'all' && !state.q ? ' projects' : ' matching')
          : '';
      }

      function reset() {
        state.list = filtered();
        state.shown = 0;
        grid.innerHTML = '';
        empty.hidden = state.list.length > 0;
        renderNext();
        updateCount();
      }

      // infinite scroll
      var io = new IntersectionObserver(function (es) {
        es.forEach(function (e) { if (e.isIntersecting && state.shown < state.list.length) renderNext(); });
      }, { rootMargin: '400px 0px' });
      io.observe(sentinel);

      // search
      var t;
      search.addEventListener('input', function () {
        clearBtn.hidden = !this.value;
        clearTimeout(t);
        var v = this.value;
        t = setTimeout(function () { state.q = v; reset(); }, 130);
      });
      clearBtn.addEventListener('click', function () { search.value = ''; clearBtn.hidden = true; state.q = ''; reset(); search.focus(); });

      // category filter
      filters.addEventListener('click', function (e) {
        var b = e.target.closest('.filt'); if (!b) return;
        filters.querySelectorAll('.filt').forEach(function (x) { x.classList.toggle('active', x === b); });
        state.cat = b.getAttribute('data-filter');
        reset();
      });

      // ---- lightbox ----
      var lb = document.getElementById('lb'), lbImg = document.getElementById('lbImg'),
          lbTitle = document.getElementById('lbTitle'), lbCat = document.getElementById('lbCat'),
          lbTags = document.getElementById('lbTags'), lbActions = document.getElementById('lbActions'),
          lbClose = document.getElementById('lbClose'), lbInner = document.getElementById('lbInner'),
          lbShot = lb.querySelector('.lb-shot');
      var lastFocus = null;

      function openLB(p) {
        lastFocus = document.activeElement;
        lbImg.src = p.img; lbImg.alt = p.title + ' — full screenshot';
        lbTitle.textContent = p.title; lbCat.textContent = p.category;
        lbTags.innerHTML = '<b>' + esc(p.platform) + '</b><b>' + esc(p.category) + '</b>';
        lbActions.innerHTML = p.live
          ? '<a class="btn primary" href="' + esc(p.live) + '" target="_blank" rel="noopener">Open live site ↗</a>'
          : '<span class="lb-caseb">Private / case study — no public URL</span>';
        lb.hidden = false; lb.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        if (lbShot) lbShot.scrollTop = 0;
        lbClose.focus();
      }
      function closeLB() {
        lb.hidden = true; lb.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        lbImg.src = '';
        if (lastFocus && lastFocus.focus) lastFocus.focus();
      }

      grid.addEventListener('click', function (e) {
        if (e.target.closest('[data-live]')) return; // let live link work
        var card = e.target.closest('.proj'); if (!card) return;
        var p = state.list[+card.getAttribute('data-idx')];
        if (p) openLB(p);
      });
      grid.addEventListener('keydown', function (e) {
        if (e.key !== 'Enter' && e.key !== ' ') return;
        var card = e.target.closest('.proj'); if (!card) return;
        e.preventDefault();
        var p = state.list[+card.getAttribute('data-idx')];
        if (p) openLB(p);
      });
      lbClose.addEventListener('click', closeLB);
      lb.addEventListener('click', function (e) { if (e.target === lb || e.target === lbInner) closeLB(); });
      document.addEventListener('keydown', function (e) { if (e.key === 'Escape' && !lb.hidden) closeLB(); });

      reset();
    });
  </script>
</Base>
