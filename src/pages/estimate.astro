---
import Base from '../layouts/Base.astro';
---
<Base active="estimate" title="Estimate — Abdul Rehman Khan" description="Instant website cost calculator — build your project and get a live estimate.">
  <section id="page-estimate" style="padding-bottom:0;">
    <div class="wrap">
      <p class="eyebrow reveal">Instant estimate</p>
      <h1 class="reveal" style="font-size:clamp(32px,5.4vw,58px);margin-bottom:16px;">What will it cost?</h1>
      <p class="sec-lead reveal" style="margin-bottom:8px;">Build your project below and watch the price update live. The <em>stack you pick changes the price</em> — WordPress is the most affordable, Shopify and custom builds cost more. Your exact quote comes after a quick chat.</p>
    </div>
  </section>
  <section style="padding-top:40px;">
    <div class="wrap calc-grid">
      <div class="calc-controls">
        <div class="calc-block reveal">
          <div class="calc-label"><span class="calc-num">01</span> Project type</div>
          <div class="seg" data-group="type">
            <button class="seg-btn active" data-val="website">Website</button>
            <button class="seg-btn" data-val="webapp">Web app</button>
            <button class="seg-btn" data-val="ecommerce">E-commerce</button>
            <button class="seg-btn" data-val="saas">SaaS platform</button>
            <button class="seg-btn" data-val="mvp">MVP / prototype</button>
          </div>
        </div>
        <div class="calc-block reveal">
          <div class="calc-label"><span class="calc-num">02</span> Platform / stack</div>
          <div class="chips" data-group="platform">
            <button class="chip-b active" data-val="wordpress">WordPress</button>
            <button class="chip-b" data-val="wix">Wix</button>
            <button class="chip-b" data-val="squarespace">Squarespace</button>
            <button class="chip-b" data-val="webflow">Webflow</button>
            <button class="chip-b" data-val="framer">Framer</button>
            <button class="chip-b" data-val="shopify">Shopify</button>
            <button class="chip-b" data-val="custom">Custom (Astro / Next.js)</button>
          </div>
        </div>
        <div class="calc-block reveal">
          <div class="calc-label"><span class="calc-num">03</span> Complexity</div>
          <div class="chips" data-group="complexity">
            <button class="chip-b active" data-val="simple">Simple</button>
            <button class="chip-b" data-val="medium">Medium</button>
            <button class="chip-b" data-val="complex">Complex</button>
            <button class="chip-b" data-val="enterprise">Enterprise</button>
          </div>
        </div>
        <div class="calc-block reveal">
          <div class="calc-label"><span class="calc-num">04</span> Pages / screens <b id="pageVal">5</b></div>
          <input type="range" id="pageRange" min="1" max="50" value="5" class="calc-range" />
          <div class="calc-scale"><span>1</span><span>25</span><span>50+</span></div>
        </div>
        <div class="calc-block reveal">
          <div class="calc-label"><span class="calc-num">05</span> Features</div>
          <div class="chips multi" data-group="features">
            <button class="chip-b" data-val="auth">User authentication</button>
            <button class="chip-b" data-val="payments">Payment integration</button>
            <button class="chip-b" data-val="api">Third-party API</button>
            <button class="chip-b" data-val="dashboard">Admin dashboard</button>
            <button class="chip-b" data-val="analytics">Analytics &amp; reporting</button>
            <button class="chip-b" data-val="cms">CMS</button>
            <button class="chip-b" data-val="responsive">Mobile responsive</button>
            <button class="chip-b" data-val="seo">SEO optimization</button>
            <button class="chip-b" data-val="multilang">Multi-language</button>
            <button class="chip-b" data-val="realtime">Real-time features</button>
          </div>
        </div>
        <div class="calc-block reveal">
          <div class="calc-label"><span class="calc-num">06</span> Timeline</div>
          <div class="chips" data-group="timeline">
            <button class="chip-b" data-val="rush">Rush (1–2 wks)</button>
            <button class="chip-b" data-val="fast">Fast (2–4 wks)</button>
            <button class="chip-b active" data-val="standard">Standard (1–2 mo)</button>
            <button class="chip-b" data-val="flexible">Flexible (2–4 mo)</button>
          </div>
        </div>
      </div>

      <aside class="calc-result reveal">
        <div class="calc-card">
          <div class="calc-card-top">
            <span class="calc-est-label">Estimated investment</span>
            <div class="cur-toggle" data-group="currency">
              <button class="cur-b active" data-val="PKR">PKR</button>
              <button class="cur-b" data-val="USD">USD</button>
              <button class="cur-b" data-val="EUR">EUR</button>
              <button class="cur-b" data-val="GBP">GBP</button>
              <button class="cur-b" data-val="AED">AED</button>
              <button class="cur-b" data-val="INR">INR</button>
            </div>
          </div>
          <div class="calc-figure"><span id="estPrice">0</span></div>
          <div class="calc-est-sub">Estimated project price · <span id="estPlatform">WordPress</span></div>
          <div class="calc-gauge"><div class="calc-gauge-fill" id="gaugeFill"></div></div>
          <div class="calc-gauge-cap"><span>Simple</span><span id="scopeLabel">Standard build</span><span>Complex</span></div>
          <ul class="calc-breakdown" id="breakdown"></ul>
          <div class="calc-actions">
            <a id="calcQuote" class="btn primary" href="#">Request exact quote →</a>
            <button id="calcChat" class="btn ghost" type="button">Discuss with assistant</button>
          </div>
          <p class="calc-note">Indicative only. Final scope &amp; price are confirmed after a short call — no obligation.</p>
        </div>
      </aside>
    </div>
  </section>
</Base>
