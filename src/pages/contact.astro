---
import Base from '../layouts/Base.astro';
import { siWhatsapp } from 'simple-icons';
const WA = '923159429998';
const EMAIL = 'ark.educationalist@gmail.com';
const CALENDLY = 'https://calendly.com/ark-educationalist/30min';
const channels = [
  { k:'wa',   h:'WhatsApp',  s:'Fastest reply — usually under an hour', v:'+92 315 9429998', href:`https://wa.me/${WA}`, cta:'Start WhatsApp chat' },
  { k:'call', h:'Call / voice note', s:'Prefer to talk it through?', v:'+92 315 9429998', href:`tel:+${WA}`, cta:'Call now' },
  { k:'mail', h:'Email', s:'Send a brief and any references', v:EMAIL, href:`mailto:${EMAIL}`, cta:'Email me' },
];
const trust = [
  ['8+','Years experience'],['90+','Projects delivered'],['3','Countries served'],['~1 day','Typical reply time'],
];
---
<Base active="contact" title="Book a Free Strategy Call — Abdul Rehman Khan" description="Book a free 30-minute strategy call with Abdul Rehman Khan, or send a project brief. CMS, custom web, e-commerce, DevOps, design and automation — replies within a day.">
  <section style="padding-bottom:0;">
    <div class="wrap">
      <p class="eyebrow reveal">Let's talk</p>
      <h1 class="reveal" style="font-size:clamp(32px,5.4vw,58px);margin-bottom:14px;">Start a conversation.</h1>
      <p class="sec-lead reveal" style="margin-bottom:36px;">A great build starts with a clear brief and a fast reply. Book a free 30-minute strategy call, or send the details below — I read every message personally and get back to you, usually within a day.</p>

      <div class="channels reveal">
        {channels.map((c) => (
          <a class="channel" href={c.href} target={c.k==='wa'?'_blank':null} rel={c.k==='wa'?'noopener':null}>
            <span class={`ch-ic ch-${c.k}`}>
              {c.k==='wa' && <svg viewBox="0 0 24 24" aria-hidden="true"><path d={siWhatsapp.path}/></svg>}
              {c.k==='call' && <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6.5 4h3l1.5 4-2 1.5a12 12 0 0 0 5 5l1.5-2 4 1.5v3a2 2 0 0 1-2.2 2A16 16 0 0 1 4.5 6.2 2 2 0 0 1 6.5 4Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>}
              {c.k==='mail' && <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M4 6h16v12H4z" stroke="currentColor" stroke-width="1.6"/><path d="m4 7 8 6 8-6" stroke="currentColor" stroke-width="1.6"/></svg>}
            </span>
            <div class="ch-body"><h3>{c.h}</h3><p>{c.s}</p><span class="ch-v">{c.v}</span><span class="ch-cta">{c.cta} →</span></div>
          </a>
        ))}
      </div>

      <div class="trust-strip reveal">
        {trust.map(([v,l]) => <div class="ts"><b>{v}</b><span>{l}</span></div>)}
        <div class="ts wide"><b>Solo, senior &amp; accountable</b><span>You work directly with me — no account managers, no hand-offs</span></div>
      </div>
    </div>
  </section>

  <section style="padding-top:48px;">
    <div class="wrap contact-grid">
      <div class="reveal">
        <h2 class="sec-title" style="font-size:clamp(24px,3.4vw,34px);">Send a project brief</h2>
        <p class="sec-lead" style="margin:8px 0 24px;">Scoped proposal back within 1 business day.</p>
        <form id="contactForm">
          <div class="field-row">
            <div class="field"><label for="cf-name">Name *</label><input id="cf-name" required placeholder="Your name" /></div>
            <div class="field"><label for="cf-email">Email *</label><input id="cf-email" type="email" required placeholder="you@company.com" /></div>
          </div>
          <div class="field-row">
            <div class="field"><label for="cf-phone">Phone / WhatsApp</label><input id="cf-phone" placeholder="Optional" /></div>
            <div class="field"><label for="cf-company">Company / brand</label><input id="cf-company" placeholder="Optional" /></div>
          </div>
          <div class="field-row">
            <div class="field"><label for="cf-type">Project type</label>
              <select id="cf-type"><option>New website</option><option>Redesign</option><option>E-commerce store</option><option>Web app / SaaS</option><option>MVP / prototype</option><option>Automation / workflow</option><option>Hosting / migration / DevOps</option><option>Graphic design / branding</option><option>Other</option></select>
            </div>
            <div class="field"><label for="cf-budget">Budget (PKR)</label>
              <select id="cf-budget"><option>PKR 100k – 250k</option><option>PKR 250k – 500k</option><option>PKR 500k – 1M</option><option>PKR 1M – 2.5M</option><option>PKR 2.5M+</option><option>Not sure yet</option></select>
            </div>
          </div>
          <div class="field"><label for="cf-timeline">Timeline</label>
            <select id="cf-timeline"><option>ASAP / rush</option><option>2–4 weeks</option><option>1–3 months</option><option>Flexible</option></select>
          </div>
          <div class="field"><label for="cf-msg">Project brief *</label><textarea id="cf-msg" required placeholder="What are you looking to build? Goals, pages/features, any reference sites…"></textarea></div>
          <input type="text" id="cf-hp" name="_gotcha" tabindex="-1" autocomplete="off" aria-hidden="true" style="position:absolute;left:-9999px;width:1px;height:1px;opacity:0;" />
          <div class="hero-cta" style="gap:10px;">
            <button type="submit" id="cfSubmit" class="btn primary">Send brief →</button>
            <button type="button" id="waBtn" class="btn wa"><svg viewBox="0 0 24 24" width="16" height="16" style="fill:currentColor" aria-hidden="true"><path d={siWhatsapp.path} /></svg> Send on WhatsApp</button>
          </div>
          <p class="form-note" id="cfStatus">Sends straight to my inbox — I reply within a day. WhatsApp works too.</p>
        </form>
      </div>

      <div class="reveal" id="book">
        <h2 class="sec-title" style="font-size:clamp(24px,3.4vw,34px);">Book a free strategy call</h2>
        <p class="sec-lead" style="margin:8px 0 20px;">Pick a 30-minute slot — we'll talk through your goals, scope and the best platform for the job. No obligation.</p>
        <div class="calendly-wrap">
          <div class="calendly-inline-widget" data-url={`${CALENDLY}?hide_gdpr_banner=1&background_color=0b0f18&text_color=eaf0f7&primary_color=34e2c5`} style="min-width:300px;height:660px;"></div>
          <noscript><a class="btn primary" href={CALENDLY} target="_blank" rel="noopener">Open my calendar ↗</a></noscript>
        </div>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ WA, EMAIL, CALENDLY }}>
    document.addEventListener('astro:page-load', function(){
      // ---- form ----
      var f=document.getElementById('contactForm');
      if(f){
        var g=function(id){var el=document.getElementById(id);return el?el.value.trim():'';};
        var brief=function(){return 'Name: '+g('cf-name')+'\nEmail: '+g('cf-email')+'\nPhone: '+(g('cf-phone')||'-')+'\nCompany: '+(g('cf-company')||'-')+'\nProject type: '+g('cf-type')+'\nBudget: '+g('cf-budget')+'\nTimeline: '+g('cf-timeline')+'\n\nBrief:\n'+g('cf-msg');};
        var statusEl=document.getElementById('cfStatus'), btn=document.getElementById('cfSubmit');
        function mailtoFallback(){var subject='Project brief — '+g('cf-name')+' ('+g('cf-type')+')';window.location.href='mailto:'+EMAIL+'?subject='+encodeURIComponent(subject)+'&body='+encodeURIComponent(brief());}
        f.onsubmit=function(e){
          e.preventDefault();
          if(!g('cf-name')||!g('cf-email')||!g('cf-msg')){statusEl.textContent='Please fill in your name, email and a brief.';statusEl.style.color='var(--amber)';return;}
          btn.disabled=true;var orig=btn.textContent;btn.textContent='Sending…';statusEl.style.color='';statusEl.textContent='Sending…';
          var payload={name:g('cf-name'),email:g('cf-email'),phone:g('cf-phone'),company:g('cf-company'),type:g('cf-type'),budget:g('cf-budget'),timeline:g('cf-timeline'),message:g('cf-msg'),_gotcha:g('cf-hp')};
          fetch('/api/contact',{method:'POST',headers:{'content-type':'application/json'},body:JSON.stringify(payload)})
            .then(function(r){return r.json();})
            .then(function(d){
              if(d&&d.ok){f.reset();statusEl.style.color='var(--accent)';statusEl.textContent='✓ Sent! I’ll get back to you within a day.';btn.textContent='Sent ✓';}
              else{ // not configured or send failed → open the user's mail app pre-filled
                statusEl.style.color='';statusEl.textContent='Opening your email app…';btn.disabled=false;btn.textContent=orig;mailtoFallback();
              }
            })
            .catch(function(){statusEl.style.color='';statusEl.textContent='Opening your email app…';btn.disabled=false;btn.textContent=orig;mailtoFallback();});
        };
        var wa=document.getElementById('waBtn');
        if(wa)wa.onclick=function(){var n=document.getElementById('cf-name'),m=document.getElementById('cf-msg');if(!n.value.trim()){n.focus();return;}if(!m.value.trim()){m.focus();return;}var text="Hi Abdul, I'd like a quote.\n\n"+brief();window.open('https://wa.me/'+WA+'?text='+encodeURIComponent(text),'_blank','noopener');};
      }
      // ---- Calendly inline widget (load once, re-init after view transitions) ----
      var wrap=document.querySelector('.calendly-inline-widget');
      if(wrap){
        function initCal(){ if(window.Calendly&&Calendly.initInlineWidget){ wrap.innerHTML=''; Calendly.initInlineWidget({url:wrap.getAttribute('data-url'),parentElement:wrap}); } }
        if(window.Calendly){ initCal(); }
        else if(!document.getElementById('calendly-js')){
          var s=document.createElement('script');s.id='calendly-js';s.src='https://assets.calendly.com/assets/external/widget.js';s.async=true;s.onload=initCal;document.body.appendChild(s);
        } else { initCal(); }
      }
    });
  </script>
</Base>
