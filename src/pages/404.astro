---
import Base from '../layouts/Base.astro';
---
<Base active="" title="404 — Page not found" description="That page doesn't exist. Head back home or explore Abdul Rehman Khan's work.">
  <section class="nf">
    <div class="aurora"><div class="blob b1"></div><div class="blob b2"></div></div>
    <div class="wrap" style="position:relative;z-index:1;text-align:center;">
      <p class="eyebrow reveal in" style="justify-content:center;">Lost?</p>
      <div class="nf-code reveal in">404</div>
      <h1 class="reveal in" style="font-size:clamp(24px,4vw,40px);margin-bottom:12px;">This page took a wrong turn.</h1>
      <p class="sec-lead reveal in" style="margin:0 auto 26px;max-width:46ch;">The link may be broken or the page moved. Let's get you back on track.</p>
      <div class="nf-links reveal in">
        <a href="/" class="btn primary">Back to home</a>
        <a href="/projects" class="btn ghost">See my work</a>
        <a href="/contact" class="btn ghost">Get in touch</a>
      </div>
    </div>
  </section>
</Base>
