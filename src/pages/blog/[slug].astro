---
export const prerender = false; // server-rendered from the database
import Base from '../../layouts/Base.astro';
import { supabase, supabaseConfigured } from '../../lib/supabase.ts';
import { marked } from 'marked';

const { slug } = Astro.params;
let post = null;
if (supabaseConfigured) {
  const { data } = await supabase
    .from('posts')
    .select('slug,title,description,body,created_at,cover,meta_title,meta_description,keywords,categories(name)')
    .eq('slug', slug).eq('published', true).maybeSingle();
  post = data || null;
}
if (!post) return Astro.redirect('/404');

const category = (post.categories && post.categories.name) || 'General';
const html = marked.parse(post.body || '', { async: false });
const fmt = (d) => new Date(d).toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' });
const readMin = Math.max(1, Math.round((post.body || '').split(/\s+/).length / 200));
const seoTitle = post.meta_title || `${post.title} — Abdul Rehman Khan`;
const seoDesc = post.meta_description || post.description;
---
<Base active="blog" title={seoTitle} description={seoDesc} keywords={post.keywords}
      ogImage={post.cover || '/images/photo.webp'} ogType="article"
      publishedTime={new Date(post.created_at).toISOString()}>
  <article class="post">
    <div class="wrap post-wrap">
      <a href="/blog" class="post-back reveal">← All posts</a>
      <p class="eyebrow reveal" style="margin-top:14px;">{category}</p>
      <h1 class="reveal">{post.title}</h1>
      <p class="post-lede reveal">{post.description}</p>
      <div class="post-meta reveal">By Abdul Rehman Khan · {fmt(post.created_at)} · {readMin} min read</div>
      {post.cover && <img class="post-cover reveal" src={post.cover} alt={post.title} />}
      <div class="post-body reveal" set:html={html}></div>
      <div class="post-cta reveal">
        <div><b>Have a project like this?</b><span>Let's talk about what you're building.</span></div>
        <a href="/contact" class="btn primary">Book a strategy call</a>
      </div>
    </div>
  </article>
</Base>
