---
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';
import IconChip from '../components/IconChip.astro';
import Pricing from '../components/Pricing.astro';
import projects from '../data/projects.json';
import { groups, allTech } from '../data/tech.mjs';

// newest first — most recently synced projects lead
const featured = [...projects].sort((a, b) => new Date(b.added || 0) - new Date(a.added || 0)).slice(0, 6);
const marquee = allTech.concat(allTech);
---
<Base active="home">
  <header class="hero">
    <div class="aurora"><div class="blob b1"></div><div class="blob b2"></div><div class="blob b3"></div></div>
    <div class="grid-ov"></div>
    <div class="spot" id="heroSpot"></div>
    <div class="wrap hero-grid">
      <div>
        <p class="eyebrow reveal">CMS Expert · Software Engineer · Karachi, PK</p>
        <h1 class="reveal">Abdul&nbsp;Rehman<br><em>Khan.</em></h1>
        <p class="hero-kicker mono reveal">&gt; <span class="rot" id="rot">CMS Expert</span></p>
        <p class="sub reveal">I'm a <b>CMS expert</b> who builds on <b>any platform</b> — WordPress, Shopify, Webflow, Wix, Squarespace, Framer, or custom Astro/Next.js — then handles the <b>hosting, DevOps, design and AI automation</b> so you get one person for the whole build. 8+ years, 90+ sites shipped.</p>
        <div class="hero-cta reveal">
          <a href="/projects" class="btn primary">View my work</a>
          <a href="/estimate" class="btn ghost">Get an estimate</a>
          <span class="avail"><span class="pulse"></span>Available for new work</span>
        </div>
      </div>
      <div class="hero-portrait reveal">
        <img src="/images/photo.webp" alt="Abdul Rehman Khan" width="620" height="740" />
        <span class="badge">Est. 2018</span>
        <span class="tag">◆ CMS · DevOps · Design · Automation</span>
      </div>
    </div>
  </header>

  <div class="wrap"><div class="marquee reveal"><div class="track">
    {marquee.map((t) => <span class="techchip"><svg viewBox="0 0 24 24" aria-hidden="true"><path d={t.path} /></svg><em>{t.label}</em></span>)}
  </div></div></div>

  <section>
    <div class="wrap about-blurb">
      <div class="reveal">
        <p class="eyebrow">About</p>
        <p class="big">I'm a <em>CMS specialist</em> who bridges <em>engineering</em>, <em>design</em> and <em>automation</em> — building on whichever platform fits, then owning the hosting, graphics and workflow automation so you don't have to hire four people.</p>
        <div class="hero-cta" style="margin-top:28px;"><a href="/about" class="btn ghost">More about me →</a></div>
      </div>
      <div class="stat-row reveal">
        <div class="stat"><div class="v"><b>8</b>+</div><div class="l">Years experience</div></div>
        <div class="stat"><div class="v"><b>90</b>+</div><div class="l">Projects shipped</div></div>
        <div class="stat"><div class="v"><b>7</b>+</div><div class="l">CMS platforms</div></div>
        <div class="stat"><div class="v"><b>1</b></div><div class="l">Person, whole build</div></div>
      </div>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="sec-head">
        <div class="reveal"><p class="eyebrow">Selected work</p><h2 class="sec-title">Six recent builds</h2></div>
        <a href="/projects" class="btn ghost reveal">View all projects →</a>
      </div>
      <div class="proj-grid">
        {featured.map((p) => <ProjectCard p={p} />)}
      </div>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="reveal" style="margin-bottom:44px;"><p class="eyebrow">Toolkit</p><h2 class="sec-title">Skills &amp; technologies</h2></div>
      <div class="skill-grid">
        {groups.map((g) => (
          <div class="skill-card reveal">
            <span class="num">{g.n}</span><h3>{g.t}</h3>
            <div class="tech-row">{g.items.map((t) => <IconChip label={t.label} path={t.path} />)}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="reveal" style="margin-bottom:36px;"><p class="eyebrow">Track record</p><h2 class="sec-title">Achievements</h2>
      <p class="sec-lead">Testimonials are being collected from recent clients — the numbers speak for the range meanwhile.</p></div>
      <div class="ach-grid reveal">
        <div class="ach"><div class="v"><b>8</b>+ yrs</div><div class="l">Professional experience</div></div>
        <div class="ach"><div class="v"><b>90</b>+</div><div class="l">Projects delivered</div></div>
        <div class="ach"><div class="v"><b>7</b></div><div class="l">Industries served</div></div>
        <div class="ach"><div class="v"><b>3</b></div><div class="l">Countries — PK · UAE · CA</div></div>
      </div>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="sec-head">
        <div class="reveal"><p class="eyebrow">Pricing</p><h2 class="sec-title">Simple, transparent packages</h2>
        <p class="sec-lead">Fixed-scope packages to start, or a custom quote for bigger builds. Prices in PKR — use the calculator for your currency.</p></div>
        <a href="/pricing" class="btn ghost reveal">Compare packages →</a>
      </div>
      <div class="reveal"><Pricing compact={true} /></div>
      <div class="reveal" style="text-align:center;margin-top:26px;"><a href="/estimate" class="btn ghost">Build a live estimate →</a></div>
    </div>
  </section>

  <section>
    <div class="wrap">
      <div class="cta-band reveal"><div class="glow"></div>
        <h2>Have a project in mind?</h2>
        <p>CMS or custom, e-commerce, design, automation or hosting — one person, from first idea to a live, production site.</p>
        <div class="hero-cta"><a href="/estimate" class="btn primary">Get an instant estimate</a><a href="/contact" class="btn ghost">Get in touch</a></div>
      </div>
    </div>
  </section>
</Base>
